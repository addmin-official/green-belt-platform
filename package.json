{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.cjs",
    "lint": "tsc --noEmit",
    "qa:mock": "node scripts/qa/check-mock-dependencies.mjs",
    "qa:sovereignty": "node scripts/qa/check-sovereign-boundaries.mjs",
    "qa:localization": "node scripts/qa/check-localization-coverage.mjs",
    "qa:typography": "node scripts/qa/check-rtl-typography.mjs",
    "qa:hardcoded-success": "node scripts/qa/check-hardcoded-success.mjs",
    "qa:demo-isolation": "node scripts/qa/check-demo-isolation.mjs",
    "qa:api-contracts": "node scripts/qa/check-api-contracts.mjs",
    "qa:openapi-contracts": "node scripts/qa/check-openapi-contracts.mjs",
    "qa:deployment-readiness": "node scripts/qa/check-deployment-readiness.mjs",
    "qa:build-output-safety": "node scripts/qa/check-build-output-safety.mjs",
    "qa:uat-dry-run": "node scripts/qa/check-uat-dry-run.mjs",
    "qa:krg-digital-compatibility": "node scripts/qa/check-krg-digital-compatibility.mjs",
    "qa:krg-onboarding-package": "node scripts/qa/check-krg-onboarding-package.mjs",
    "qa:pitch-package": "node scripts/qa/check-pitch-package.mjs",
    "qa:outreach-package": "node scripts/qa/check-outreach-package.mjs",
    "qa:training-package": "node scripts/qa/check-training-package.mjs",
    "qa:ui-containment": "node scripts/qa/check-ui-containment.mjs",
    "qa:fiscal-settlement-policy": "node scripts/qa/check-fiscal-settlement-policy.mjs",
    "qa:border-settlement-policy": "node scripts/qa/check-border-settlement-policy.mjs",
    "qa:border-scope-lock": "node scripts/qa/check-border-scope-lock.mjs",
    "qa:border-api-surface": "node scripts/qa/check-border-api-surface.mjs",
    "qa:production-gate": "node scripts/qa/run-production-gate.mjs",

    "backend:build": "npm run --prefix server build",
    "backend:qa": "npm run --prefix server qa:safety",
    "backend:dev": "npm run --prefix server dev",
    "dev:frontend": "vite",
    "dev:backend": "npm run --prefix server dev",
    "dev:all": "npm run dev:frontend & npm run dev:backend",
    "build:frontend": "vite build",
    "build:backend": "npm run --prefix server build",
    "qa:all": "npm run qa:production-gate && npm run qa:border-api-surface && npm run qa:ui-containment && npm run qa:uat-dry-run && npm run qa:krg-digital-compatibility && npm run qa:krg-onboarding-package && npm run qa:pitch-package && npm run qa:outreach-package && npm run qa:training-package && npm run backend:qa",
    "smoke:local": "node scripts/smoke/run-local-smoke.mjs",
    "release:staging-check": "node scripts/release/staging-release-check.mjs"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
