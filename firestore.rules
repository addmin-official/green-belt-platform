rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userData() {
      return get(
        /databases/$(database)/documents/users/$(request.auth.uid)
      ).data;
    }

    function hasActiveRole(role) {
      return signedIn()
        && userData().active == true
        && userData().role == role;
    }

    function isAdmin() {
      return hasActiveRole("admin");
    }

    function isOperator() {
      return hasActiveRole("operator");
    }

    function isViewer() {
      return hasActiveRole("viewer");
    }

    function canReadPlatform() {
      return isAdmin() || isOperator() || isViewer();
    }

    function canManagePlatform() {
      return isAdmin() || isOperator();
    }

    match /publicContent/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if signedIn()
        && (
          request.auth.uid == userId
          || isAdmin()
        );

      allow create, update, delete: if isAdmin();
    }

    match /restaurants/{document=**} {
      allow read: if canReadPlatform();
      allow create, update: if canManagePlatform();
      allow delete: if isAdmin();
    }

    match /collections/{document=**} {
      allow read: if canReadPlatform();
      allow create, update: if canManagePlatform();
      allow delete: if isAdmin();
    }

    match /compostBatches/{document=**} {
      allow read: if canReadPlatform();
      allow create, update: if canManagePlatform();
      allow delete: if isAdmin();
    }

    match /impactProjects/{document=**} {
      allow read: if canReadPlatform();
      allow create, update: if canManagePlatform();
      allow delete: if isAdmin();
    }

    match /pilotMetrics/{document=**} {
      allow read: if canReadPlatform();
      allow create, update: if canManagePlatform();
      allow delete: if isAdmin();
    }

    match /announcements/{document=**} {
      allow read: if canReadPlatform();
      allow create, update, delete: if isAdmin();
    }

    match /auditLogs/{document=**} {
      allow read: if canReadPlatform();
      allow create: if canManagePlatform();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
