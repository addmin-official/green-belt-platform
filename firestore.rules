rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function hasActiveRole(role) {
      return signedIn() && userData().active == true && userData().role == role;
    }
    function hasAnyRole(roles) {
      return signedIn() && userData().active == true && userData().role in roles;
    }
    function isAdmin() { return hasActiveRole('admin'); }
    function canReadPlatform() {
      return hasAnyRole(['admin','operator','collection_officer','facility_operator','qa_manager','laboratory','viewer']);
    }
    function canOperate() {
      return hasAnyRole(['admin','operator','collection_officer','facility_operator']);
    }

    match /publicContent/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /restaurants/{document=**} {
      allow read: if canReadPlatform();
      allow create, update: if hasAnyRole(['admin','operator']);
      allow delete: if isAdmin();
    }

    match /collectionEvents/{document=**} {
      allow read: if canReadPlatform();
      allow create: if hasAnyRole(['admin','operator','collection_officer']) && request.resource.data.weightKg > 0;
      allow update: if hasAnyRole(['admin','operator']);
      allow delete: if false;
    }

    match /manifests/{document=**} {
      allow read: if canReadPlatform();
      allow create, update: if canOperate();
      allow delete: if false;
    }

    match /facilityReceipts/{document=**} {
      allow read: if canReadPlatform();
      allow create, update: if hasAnyRole(['admin','operator','facility_operator']);
      allow delete: if false;
    }

    match /compostBatches/{document=**} {
      allow read: if canReadPlatform();
      allow create: if hasAnyRole(['admin','operator','facility_operator']);
      allow update: if hasAnyRole(['admin','operator','facility_operator','qa_manager']);
      allow delete: if false;
    }

    match /processReadings/{document=**} {
      allow read: if canReadPlatform();
      allow create: if hasAnyRole(['admin','operator','facility_operator']);
      allow update, delete: if false;
    }

    match /samples/{document=**} {
      allow read: if canReadPlatform();
      allow create, update: if hasAnyRole(['admin','operator','facility_operator','qa_manager','laboratory']);
      allow delete: if false;
    }

    match /laboratoryResults/{document=**} {
      allow read: if canReadPlatform();
      allow create, update: if hasAnyRole(['admin','laboratory']);
      allow delete: if false;
    }

    match /qaReleases/{document=**} {
      allow read: if canReadPlatform();
      allow create: if hasAnyRole(['admin','qa_manager']) && request.resource.data.locked == true;
      allow update, delete: if false;
    }

    match /auditLogs/{document=**} {
      allow read: if hasAnyRole(['admin','operator','qa_manager']);
      allow create: if canOperate() || hasAnyRole(['qa_manager','laboratory']);
      allow update, delete: if false;
    }

    match /incidents/{document=**} {
      allow read: if canReadPlatform();
      allow create, update: if canOperate() || hasActiveRole('qa_manager');
      allow delete: if false;
    }

    match /impactProjects/{document=**} {
      allow read: if canReadPlatform();
      allow create, update: if hasAnyRole(['admin','operator']);
      allow delete: if isAdmin();
    }

    match /pilotMetrics/{document=**} {
      allow read: if canReadPlatform();
      allow create, update: if hasAnyRole(['admin','operator']);
      allow delete: if isAdmin();
    }

    match /announcements/{document=**} {
      allow read: if canReadPlatform();
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
