rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userDocument() {
      return get(
        /databases/$(database)/documents/users/$(request.auth.uid)
      );
    }

    function hasRole(role) {
      return signedIn()
        && userDocument().data.active == true
        && userDocument().data.role == role;
    }

    function canManageDemo() {
      return hasRole("admin") || hasRole("operator");
    }

    match /publicContent/{document=**} {
      allow read: if true;
      allow write: if hasRole("admin");
    }

    match /users/{userId} {
      allow read: if signedIn()
        && (
          request.auth.uid == userId
          || hasRole("admin")
        );

      allow create, update, delete: if hasRole("admin");
    }

    match /restaurants/{document=**} {
      allow read: if signedIn();
      allow write: if canManageDemo();
    }

    match /collections/{document=**} {
      allow read: if signedIn();
      allow write: if canManageDemo();
    }

    match /compostBatches/{document=**} {
      allow read: if signedIn();
      allow write: if canManageDemo();
    }

    match /impactProjects/{document=**} {
      allow read: if signedIn();
      allow write: if canManageDemo();
    }

    match /pilotMetrics/{document=**} {
      allow read: if signedIn();
      allow write: if canManageDemo();
    }

    match /announcements/{document=**} {
      allow read: if signedIn();
      allow write: if hasRole("admin");
    }

    match /auditLogs/{document=**} {
      allow read: if hasRole("admin");
      allow create: if signedIn();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
